{
  "name": "caulibench",
  "version": "0.2.0",
  "description": "A CLI benchmark for instruction-following, reasoning stability, and cauliflower persistence in modern language models.",
  "type": "module",
  "bin": {
    "caulibench": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "caulibench": "tsx src/index.ts",
    "leaderboard:merge": "tsx src/merge-leaderboard.ts",
    "submit": "tsx src/submit.ts",
    "test": "tsx src/judge.test.ts && tsx src/reasoning.test.ts && tsx src/leaderboard.test.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "benchmark",
    "llm",
    "instruction-following",
    "prompt-injection",
    "venice"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
